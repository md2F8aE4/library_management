<?xml version="1.0" encoding="utf-8"?>
<odoo>

<data>

<record id="book_search_view" model="ir.ui.view">
    <field name="name">book.search.view</field>
    <field name="model">library.book</field>
    <field name="arch" type="xml">
        <search>
            <filter string="Published Date"
                    name="published_date"
                    domain="[('published_date','!=',False)]"/>

            <filter string="Group By Author"
                    name="group_by_author"
                    context="{'group_by':'author'}"/>
        </search>
    </field>
</record>

<record id="book_tree_view" model="ir.ui.view">
    <field name="name">book.tree.view</field>
    <field name="model">library.book</field>
    <field name="arch" type="xml">
        <tree>
            <field name="name"/>
            <field name="author"/>
            <field name="product_id"/>
            <field name="quantity"/>
            <field name="price_unit"/>
            <field name="state"/>
        </tree>
    </field>
</record>

<record id="book_form_view" model="ir.ui.view">
    <field name="name">book.form.view</field>
    <field name="model">library.book</field>
    <field name="arch" type="xml">

        <form string="Book">
        
            <header>

                <field name="invoice_id" invisible="1"/>
                <field name="delivery_id" invisible="1"/>
        
                <button name="action_borrow"
                        type="object"
                        string="Borrow"
                        class="oe_highlight"
                        invisible="state != 'available'"/>

                <button name="action_set_available"
                        type="object"
                        string="Set To Available"/>

                <button name="action_set_borrowed"
                        type="object"
                        string="Set To Borrowed"
                        invisible="1"/>

                <button name="action_set_returned"
                        type="object"
                        string="Set To Returned"/>

                <field name="state"
                       widget="statusbar"
                       statusbar_visible="available,borrowed,returned"/>

               

            </header>

            <sheet>
            <field name="borrow_count" widget="statinfo" />
               <button name="action_view_borrow_history"
                       type="object"
                       string="Borrow History"
                       class="oe_stat_button"
                        icon="fa-book"/>
             <div name = 'button_box' >
            <button class="oe_stat_button"
                type="object"
                icon="fa-file-text-o"
                name="action_view_customer_invoices">
                <field name="invoice_count" widget="statinfo" string="Invoices"/>
                </button>
                 </div> 
                 <group string="Borrow Information">

                      <field name="availability"/>

                       <field name="current_borrower_id"/>

                         <field name="borrow_count"/>

                 </group>

                <group>
                    <group>
                        <field name="name" required="1"/>
                        <field name="author" required="1"/>
                        <field name="published_date" required="1"/>
                    </group>

                    <group>
                        <field name="customer_id"/>
                        <field name="availability" readonly="1"/>
                    </group>
                </group>

                <group string="Product Information">
                    <field name="product_id" required="1"/>
                    <field name="quantity"/>
                    <field name="price_unit" readonly="1"/>
                </group>

                <group string="Description">
                    <field name="description"/>
                </group>

            </sheet>
            <div class ="oe_chatter">
            <field name = "message_follower_ids" widget="mail_followers"/>
             <field name = "activity_ids" widget="mail_activity"/>
              <field name = "message_ids" widget="mail_thread"/>
              </div>

        </form>
        
    </field>
</record>

<record id="book_action" model="ir.actions.act_window">
    <field name="name">Books</field>
    <field name="res_model">library.book</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="book_search_view"/>
</record>


</data>

</odoo>
